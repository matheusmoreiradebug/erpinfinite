# Supabase — copie para .env.local e preencha com as chaves do seu projeto
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key-publica"

# Opcional — só para scripts administrativos no servidor. NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-secreta"
